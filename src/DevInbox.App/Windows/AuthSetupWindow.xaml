<Window x:Class="DevInbox.App.Windows.AuthSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Integrações — DevInbox"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        Style="{StaticResource GitHubWindow}"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Integrações" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="Conecte o DevInbox às suas ferramentas de trabalho."
                   Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap" />

        <Border Background="{DynamicResource Brush.Surface}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="8"
                Padding="16" Margin="0,16,0,0">
            <StackPanel>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" VerticalAlignment="Center" />
                        <TextBlock Text="GitHub" FontWeight="SemiBold" FontSize="14"
                                   Margin="9,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="StatusText" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}" />
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Usar GitHub CLI" Click="OnUseGhCli" />
                    <Button x:Name="TokenToggleButton" Content="Usar token…" Click="OnToggleToken" Margin="8,0,0,0" />
                    <Button x:Name="RemoveTokenButton" Content="Remover token" Click="OnRemoveToken"
                            Margin="8,0,0,0" Visibility="Collapsed" />
                </StackPanel>

                <StackPanel x:Name="TokenPanel" Visibility="Collapsed" Margin="0,14,0,0">
                    <PasswordBox x:Name="TokenBox" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="ValidateButton" Content="Validar e salvar"
                                Click="OnValidateAndSave" Style="{StaticResource PrimaryButton}" />
                        <TextBlock VerticalAlignment="Center" Margin="12,0,0,0">
                            <Hyperlink NavigateUri="https://github.com/settings/tokens/new?scopes=repo,notifications&amp;description=DevInbox"
                                       RequestNavigate="OnNavigate">Gerar token…</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap"
                               Margin="0,8,0,0" FontSize="12"
                               Text="Token classic com escopos repo e notifications. Fica salvo só nesta máquina, criptografado (DPAPI)." />
                </StackPanel>

                <TextBlock x:Name="FeedbackText" TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
