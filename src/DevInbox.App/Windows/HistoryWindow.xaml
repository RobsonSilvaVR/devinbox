<Window x:Class="DevInbox.App.Windows.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevInbox"
        Width="880" Height="520"
        MinWidth="720" MinHeight="360"
        Style="{StaticResource GitHubWindow}"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <TabControl x:Name="MainTabs" Margin="12">
        <TabItem Header="{Binding ThreadsHeader}">
            <DockPanel Margin="0,10,0,0">
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,10"
                           Text="Conversas de review ainda abertas nos seus PRs (ou em que você participa). Ao serem resolvidas, saem desta lista e o evento vai para o histórico."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.TextMuted}" />
                <ListView ItemsSource="{Binding Threads}" MouseDoubleClick="OnThreadDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Repositório" Width="165" DisplayMemberBinding="{Binding Repo}" />
                            <GridViewColumn Header="PR" Width="55" DisplayMemberBinding="{Binding PrLabel}" />
                            <GridViewColumn Header="Comentário" Width="380">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Preview}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PrTitle}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Autor" Width="100" DisplayMemberBinding="{Binding Author}" />
                            <GridViewColumn Header="Origem" Width="90" DisplayMemberBinding="{Binding Participation}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>
        <TabItem Header="Histórico">
            <DockPanel Margin="0,10,0,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right"
                            Content="Marcar todas como lidas"
                            Command="{Binding MarkAllReadCommand}" />
                    <TextBlock Text="Clique duplo em um item abre o PR no navegador e o marca como lido."
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextMuted}" />
                </DockPanel>
                <ListView ItemsSource="{Binding Items}" MouseDoubleClick="OnItemDoubleClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRead}" Value="False">
                                    <Setter Property="Background" Value="#2E1F6FEB" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="26">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UnreadDot}"
                                                   Foreground="{DynamicResource Brush.Accent}"
                                                   HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Tipo" Width="120" DisplayMemberBinding="{Binding TypeLabel}" />
                            <GridViewColumn Header="Repositório" Width="170" DisplayMemberBinding="{Binding Repo}" />
                            <GridViewColumn Header="PR" Width="55" DisplayMemberBinding="{Binding PrLabel}" />
                            <GridViewColumn Header="Título" Width="230">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="{Binding TitleWeight}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Preview}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Autor" Width="95" DisplayMemberBinding="{Binding Actor}" />
                            <GridViewColumn Header="Quando" Width="100" DisplayMemberBinding="{Binding When}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
