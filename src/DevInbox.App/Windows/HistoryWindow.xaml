<Window x:Class="DevInbox.App.Windows.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DevInbox"
        Width="920" Height="540"
        MinWidth="780" MinHeight="380"
        Style="{StaticResource GitHubWindow}"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterScreen">
    <TabControl x:Name="MainTabs" Margin="12">
        <TabItem Header="{Binding PendingHeader}">
            <DockPanel Margin="0,10,0,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Repositório:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource Brush.TextMuted}" />
                    <ComboBox Width="190" ItemsSource="{Binding PendingRepoOptions}"
                              SelectedItem="{Binding PendingRepoFilter}" />
                    <TextBlock Text="Tipo:" VerticalAlignment="Center" Margin="14,0,6,0"
                               Foreground="{DynamicResource Brush.TextMuted}" />
                    <ComboBox Width="140" ItemsSource="{Binding PendingTypeOptions}"
                              SelectedItem="{Binding PendingTypeFilter}" />
                </StackPanel>
                <ListView ItemsSource="{Binding PendingView}" MouseDoubleClick="OnPendingDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Tipo" Width="90" DisplayMemberBinding="{Binding TypeLabel}" />
                            <GridViewColumn Header="Repositório" Width="165" DisplayMemberBinding="{Binding Repo}" />
                            <GridViewColumn Header="PR" Width="55" DisplayMemberBinding="{Binding PrLabel}" />
                            <GridViewColumn Header="Detalhe" Width="360">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Detail}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PrTitle}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Autor" Width="100" DisplayMemberBinding="{Binding Author}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>
        <TabItem Header="Histórico">
            <DockPanel Margin="0,10,0,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right"
                            Content="Marcar todas como lidas"
                            Command="{Binding MarkAllReadCommand}" Margin="8,0,0,0" />
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="170" ItemsSource="{Binding HistoryRepoOptions}"
                                  SelectedItem="{Binding HistoryRepoFilter}" />
                        <ComboBox Width="150" Margin="8,0,0,0" ItemsSource="{Binding HistoryTypeOptions}"
                                  SelectedItem="{Binding HistoryTypeFilter}" />
                        <ComboBox Width="110" Margin="8,0,0,0" ItemsSource="{Binding ReadOptions}"
                                  SelectedItem="{Binding ReadFilter}" />
                        <ComboBox Width="150" Margin="8,0,0,0" ItemsSource="{Binding PeriodOptions}"
                                  SelectedItem="{Binding PeriodFilter}" />
                    </StackPanel>
                </DockPanel>
                <ListView ItemsSource="{Binding ItemsView}" MouseDoubleClick="OnItemDoubleClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRead}" Value="False">
                                    <Setter Property="Background" Value="#2E1F6FEB" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="" Width="26">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding UnreadDot}"
                                                   Foreground="{DynamicResource Brush.Accent}"
                                                   HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Tipo" Width="120" DisplayMemberBinding="{Binding TypeLabel}" />
                            <GridViewColumn Header="Repositório" Width="170" DisplayMemberBinding="{Binding Repo}" />
                            <GridViewColumn Header="PR" Width="55" DisplayMemberBinding="{Binding PrLabel}" />
                            <GridViewColumn Header="Título" Width="230">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="{Binding TitleWeight}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Preview}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Autor" Width="95" DisplayMemberBinding="{Binding Actor}" />
                            <GridViewColumn Header="Quando" Width="100" DisplayMemberBinding="{Binding When}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
