    <SolidColorBrush x:Key="Brush.ButtonHover" Color="#EBEEF1" />
    <SolidColorBrush x:Key="Brush.Primary" Color="#1F883D" />
    <SolidColorBrush x:Key="Brush.PrimaryHover" Color="#1A7F37" />
