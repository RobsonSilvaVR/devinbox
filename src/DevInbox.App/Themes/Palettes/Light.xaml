<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Claro (GitHub Light) -->
    <SolidColorBrush x:Key="Brush.Canvas" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#F6F8FA" />
    <SolidColorBrush x:Key="Brush.Border" Color="#D0D7DE" />
    <SolidColorBrush x:Key="Brush.Text" Color="#1F2328" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#656D76" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#0969DA" />
    <SolidColorBrush x:Key="Brush.Danger" Color="#CF222E" />
